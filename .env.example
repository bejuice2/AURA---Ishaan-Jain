# Copy this file to .env and replace placeholders with private local values.
OPENAI_API_KEY=replace_with_your_openai_api_key

# Runtime. Render supplies PORT automatically.
AURA_ENV=development
PORT=8000
AURA_DATA_DIR=.
AURA_TIMEZONE=America/Chicago
AURA_PUBLIC_DEMO=false
AURA_ALLOWED_ORIGINS=

AURA_CAREGIVER_MODEL=gpt-5-mini
AURA_PATIENT_MODEL=gpt-5-mini
AURA_OPENAI_TIMEOUT=30
AURA_OPENAI_RETRIES=5
AURA_TASK_GRACE_PERIOD_MINUTES=30

# Choose private admin credentials. Never commit the real values.
AURA_ADMIN_USERNAME=replace_with_admin_username
AURA_ADMIN_PASSWORD=replace_with_a_strong_admin_password

# Optional: required only for SMS text alerts.
TWILIO_ACCOUNT_SID=replace_with_twilio_account_sid
TWILIO_AUTH_TOKEN=replace_with_twilio_auth_token
TWILIO_FROM_PHONE=+15551234567
